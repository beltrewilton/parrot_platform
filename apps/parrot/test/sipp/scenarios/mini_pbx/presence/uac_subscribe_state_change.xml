<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  State Change Notification Scenario

  Subscribe and wait for state changes when extension receives a call.
  This scenario subscribes and waits for multiple NOTIFYs.

  Note: This is a simplified version that just subscribes and waits
  for state change NOTIFYs. In a full test, another SIPp instance
  would call the extension to trigger state changes.
-->

<scenario name="State Change Notification">

  <!-- SUBSCRIBE to extension 1001 -->
  <send retrans="500">
    <![CDATA[
      SUBSCRIBE sip:1001@[remote_ip]:[remote_port] SIP/2.0
      Via: SIP/2.0/[transport] [local_ip]:[local_port];branch=[branch]
      Max-Forwards: 70
      From: <sip:watcher@[local_ip]>;tag=[call_number]
      To: <sip:1001@[remote_ip]:[remote_port]>
      Call-ID: [call_id]
      CSeq: 1 SUBSCRIBE
      Contact: <sip:watcher@[local_ip]:[local_port]>
      Event: presence
      Expires: 3600
      Accept: application/pidf+xml
      Content-Length: 0
    ]]>
  </send>

  <!-- Expect 200 OK -->
  <recv response="200" timeout="5000"/>

  <!-- Expect initial NOTIFY with presence state -->
  <recv request="NOTIFY" timeout="5000">
    <action>
      <!-- Verify PIDF body contains presence info -->
      <ereg regexp="presence" search_in="body" check_it="true"/>
    </action>
  </recv>

  <!-- Send 200 OK for initial NOTIFY -->
  <send>
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

  <!-- Wait for potential state change NOTIFYs (optional) -->
  <!-- In coordinated tests, another SIPp would trigger state changes -->
  <recv request="NOTIFY" timeout="10000" optional="true"/>

  <!-- Send 200 OK for state change NOTIFY if received -->
  <send optional="true">
    <![CDATA[
      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0
    ]]>
  </send>

</scenario>
