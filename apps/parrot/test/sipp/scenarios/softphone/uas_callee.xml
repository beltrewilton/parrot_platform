<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!--
  UAS scenario: Callee receiving call from Softphone

  Simulates answering a call from the softphone:
  1. Receive INVITE
  2. Send 180 Ringing
  3. Send 200 OK
  4. Receive ACK
  5. Wait
  6. Receive BYE (or send BYE)
  7. Send 200 OK

  This is used to test SoftphoneClient's outgoing call handling.

  RFC References:
  - RFC 3261: SIP: Session Initiation Protocol
-->

<scenario name="UAS Callee">
  <!-- Step 1: Receive INVITE -->
  <recv request="INVITE" crlf="true">
    <action>
      <ereg regexp="Contact: *<([^>]+)>" search_in="msg" check_it="true" assign_to="1,contact"/>
    </action>
  </recv>

  <!-- Step 2: Send 180 Ringing -->
  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag00[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:bob@[local_ip]:[local_port]>
      Content-Length: 0

    ]]>
  </send>

  <!-- Small delay -->
  <pause milliseconds="200"/>

  <!-- Step 3: Send 200 OK with SDP answer -->
  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag00[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:bob@[local_ip]:[local_port]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=sipp 1 1 IN IP4 [local_ip]
      s=SIPp Call
      c=IN IP4 [local_ip]
      t=0 0
      m=audio [local_port+100] RTP/AVP 8
      a=rtpmap:8 PCMA/8000

    ]]>
  </send>

  <!-- Step 4: Receive ACK -->
  <recv request="ACK" crlf="true"/>

  <!-- Step 5: Wait for BYE -->
  <recv request="BYE" crlf="true"/>

  <!-- Step 6: Send 200 OK for BYE -->
  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

</scenario>
