<?xml version="1.0" encoding="UTF-8" ?>
<!--
  UAS Fork Target Slow - B-Leg Scenario

  Acts as a fork target that answers slowly (after other targets).
  Used to test "first answer wins" fork strategy - this target should
  receive a CANCEL because the fast target answers first.

  This target would answer after 1500ms, but uas_fork_target_fast.xml
  answers after 200ms and wins.

  Flow:
  1. Receive INVITE from B2BUA forker
  2. Send 100 Trying
  3. Send 180 Ringing
  4. Receive CANCEL (fast target won)
  5. Send 200 OK for CANCEL
  6. Send 487 Request Terminated for original INVITE

  If somehow we answer first:
  1-4. Same as above
  5. Send 200 OK (we won)
  6. Receive ACK
  7. Wait for BYE

  Use with: uac_fork_simultaneous.xml + uas_fork_target_fast.xml

  RFC References:
  - RFC 3261 Section 16.7: Forking
  - RFC 3261 Section 9.2: CANCEL handling
-->
<scenario name="UAS Fork Target Slow">
  <!-- Receive INVITE from forker -->
  <recv request="INVITE" crlf="true">
  </recv>

  <!-- Send 100 Trying -->
  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:slow-target@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <!-- Slow pause - we should be CANCELed before this completes -->
  <pause milliseconds="1500"/>

  <!-- Expected: Receive CANCEL (because fast target already answered) -->
  <recv request="CANCEL" optional="true">
  </recv>

  <!-- Send 200 OK for CANCEL -->
  <send optional="true">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Send 487 Request Terminated for the original INVITE -->
  <send optional="true">
    <![CDATA[

      SIP/2.0 487 Request Terminated
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      CSeq: 1 INVITE
      Content-Length: 0

    ]]>
  </send>

  <!-- Receive ACK for 487 -->
  <recv request="ACK" optional="true">
  </recv>

  <!-- Alternative path: If we somehow win (answer before CANCEL) -->
  <!-- Send 200 OK with SDP -->
  <send optional="true">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      CSeq: 1 INVITE
      Contact: <sip:slow-target@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=slow-target 654321 654321 IN IP4 [local_ip]
      s=Fork Target Slow
      c=IN IP4 [local_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-16
      a=sendrecv

    ]]>
  </send>

  <!-- If we won: Receive ACK -->
  <recv request="ACK" optional="true">
  </recv>

  <!-- If we won: Wait for BYE -->
  <recv request="BYE" optional="true" timeout="5000">
  </recv>

  <!-- Send 200 OK for BYE if received -->
  <send optional="true">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

</scenario>
