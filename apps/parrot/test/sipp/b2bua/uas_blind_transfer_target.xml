<?xml version="1.0" encoding="UTF-8" ?>
<!--
  UAS Blind Transfer Target - C-Leg Scenario

  Acts as the transfer target (C) for blind transfer testing.
  This is the destination that B-leg gets transferred to.

  Flow:
  1. Receive INVITE from B2BUA (transfer destination)
  2. Send 100 Trying, 180 Ringing
  3. Send 200 OK with SDP
  4. Receive ACK - now connected to B-leg via B2BUA
  5. Wait for call end
  6. Receive BYE
  7. Send 200 OK

  The INVITE may contain Referred-By header indicating the transferor.

  Use with: uac_blind_transfer.xml and uas_blind_transfer_bleg.xml

  RFC References:
  - RFC 3515: The Session Initiation Protocol (SIP) Refer Method
  - RFC 3892: The Session Initiation Protocol (SIP) Referred-By Mechanism
-->
<scenario name="UAS Blind Transfer Target">
  <!-- Receive INVITE from B2BUA (transfer destination) -->
  <recv request="INVITE" crlf="true">
  </recv>

  <!-- Send 100 Trying -->
  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:charlie@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <!-- Brief pause to simulate ringing -->
  <pause milliseconds="500"/>

  <!-- Send 200 OK with SDP -->
  <send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:charlie@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=charlie 789012 789012 IN IP4 [local_ip]
      s=B2BUA Transfer Target
      c=IN IP4 [local_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-16
      a=sendrecv

    ]]>
  </send>

  <!-- Receive ACK - now connected to B-leg -->
  <recv request="ACK" crlf="true">
  </recv>

  <!-- Call established after transfer, wait -->
  <pause milliseconds="3000"/>

  <!-- Receive BYE (from either B-leg or B2BUA) -->
  <recv request="BYE" timeout="10000">
  </recv>

  <!-- Send 200 OK for BYE -->
  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

</scenario>
