<?xml version="1.0" encoding="UTF-8" ?>
<!--
  UAS Blind Transfer - B-Leg Scenario

  Acts as the initial B-leg destination before transfer.
  After the call is established, B2BUA will disconnect this leg
  when the transfer target (C) answers.

  Flow:
  1. Receive INVITE from B2BUA
  2. Send 100 Trying, 180 Ringing
  3. Send 200 OK with SDP
  4. Receive ACK - call established
  5. Wait for transfer to happen
  6. Receive BYE from B2BUA (A-leg initiated transfer)
  7. Send 200 OK

  Use with: uac_blind_transfer.xml and uas_blind_transfer_target.xml

  RFC References:
  - RFC 3515: The Session Initiation Protocol (SIP) Refer Method
-->
<scenario name="UAS Blind Transfer - B-Leg">
  <!-- Receive INVITE from B2BUA -->
  <recv request="INVITE" crlf="true">
  </recv>

  <!-- Send 100 Trying -->
  <send>
    <![CDATA[

      SIP/2.0 100 Trying
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Send 180 Ringing -->
  <send>
    <![CDATA[

      SIP/2.0 180 Ringing
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
      Content-Length: 0

    ]]>
  </send>

  <!-- Brief pause -->
  <pause milliseconds="300"/>

  <!-- Send 200 OK with SDP -->
  <send retrans="500">
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag01[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Contact: <sip:bob@[local_ip]:[local_port];transport=[transport]>
      Content-Type: application/sdp
      Content-Length: [len]

      v=0
      o=bob 654321 654321 IN IP4 [local_ip]
      s=B2BUA Transfer Test B-Leg
      c=IN IP4 [local_ip]
      t=0 0
      m=audio [media_port] RTP/AVP 0 8 101
      a=rtpmap:0 PCMU/8000
      a=rtpmap:8 PCMA/8000
      a=rtpmap:101 telephone-event/8000
      a=fmtp:101 0-16
      a=sendrecv

    ]]>
  </send>

  <!-- Receive ACK -->
  <recv request="ACK" crlf="true">
  </recv>

  <!-- Wait for transfer to be initiated by A-leg -->
  <!-- We will receive BYE when transfer target answers -->
  <recv request="BYE" timeout="10000">
  </recv>

  <!-- Send 200 OK for BYE -->
  <send>
    <![CDATA[

      SIP/2.0 200 OK
      [last_Via:]
      [last_From:]
      [last_To:]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

</scenario>
