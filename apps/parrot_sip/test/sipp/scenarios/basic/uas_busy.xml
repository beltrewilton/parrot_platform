<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE scenario SYSTEM "sipp.dtd">

<!-- SIPp UAS scenario: Receive INVITE and respond with 486 Busy Here -->

<scenario name="UAS Busy">
  <!-- Receive INVITE -->
  <recv request="INVITE" crlf="true">
  </recv>

  <!-- Send 486 Busy Here -->
  <send>
    <![CDATA[
      SIP/2.0 486 Busy Here
      [last_Via:]
      [last_From:]
      [last_To:];tag=[pid]SIPpTag[call_number]
      [last_Call-ID:]
      [last_CSeq:]
      Content-Length: 0

    ]]>
  </send>

  <!-- Receive ACK -->
  <recv request="ACK" crlf="true">
  </recv>

</scenario>
